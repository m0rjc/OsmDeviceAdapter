        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (endpoint, le) (rate(osm_api_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P95 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (endpoint, le) (rate(osm_api_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P99 {{endpoint}}",
          "refId": "B"
        }
      ],
      "title": "OSM API Latency — Correlation with Rate Limits",
      "type": "timeseries"
    },
