      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "min(osm_rate_limit_remaining)",
          "legendFormat": "Min remaining",
          "refId": "A"
        }
      ],
      "title": "Worst-Case Rate Limit Remaining Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Count of users in warning and critical states over time. Normally both are zero. A spike here means investigate the per-user detail section below.",
